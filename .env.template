# Environment Configuration Template
# Copy this to .env and fill in your local values

# LLM Configuration
LLM_MODEL=llama3.3
LLM_ENDPOINT=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_NUM_PASSES=10
LLM_CONTEXT_WINDOW=8192          # Ollama num_ctx; large enough for full articles (model must support it)
LLM_MAX_TOKENS=512

# Storage Configuration
DATA_DIR=./data
LOGS_DIR=./logs

# Article Source: The Guardian Content API
# 'test' works for development; register a free key at
# https://open-platform.theguardian.com/ for production use.
GUARDIAN_API_KEY=test
GUARDIAN_SECTION=world
GUARDIAN_FROM_DAYS=7
GUARDIAN_ORDER_BY=relevance
SCRAPER_MAX_ARTICLES=25
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_FACTOR=2.0
USE_SYSTEM_TRUSTSTORE=true       # verify TLS via OS trust store (needed behind a TLS-inspecting proxy)

# Assessment Agent Configuration
CONFIDENCE_THRESHOLD=0.6

# Agent Communication
AGENT_TIMEOUT_SECONDS=300
ENABLE_DEBUG_LOGGING=false
